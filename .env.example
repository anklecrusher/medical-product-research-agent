# Application
MEDICAL_RESEARCH_APP_ENV=local
MEDICAL_RESEARCH_LOG_LEVEL=INFO

# Local-first runtime directories
MEDICAL_RESEARCH_DATA_DIR=data
MEDICAL_RESEARCH_OUTPUTS_DIR=outputs
MEDICAL_RESEARCH_CACHE_DIR=cache
MEDICAL_RESEARCH_UPLOADS_DIR=uploads

# External APIs are optional and should be configured explicitly.
# Default stays local/mock and does not call any external service.
MEDICAL_RESEARCH_LLM_PROVIDER=mock
MEDICAL_RESEARCH_LLM_MODEL=mock-medical-research-model

# For OpenAI-compatible third-party APIs, set:
# MEDICAL_RESEARCH_LLM_PROVIDER=openai_compatible
# MEDICAL_RESEARCH_LLM_BASE_URL=https://api.example.com/v1
# MEDICAL_RESEARCH_LLM_MODEL=your-model-name
# MEDICAL_RESEARCH_LLM_API_KEY=your-api-key
MEDICAL_RESEARCH_LLM_BASE_URL=https://api.openai.com/v1
MEDICAL_RESEARCH_LLM_API_KEY=
MEDICAL_RESEARCH_LLM_TIMEOUT_SECONDS=60
MEDICAL_RESEARCH_LLM_MAX_RETRIES=2

# Privacy gates. Keep private sources local unless you explicitly change this.
MEDICAL_RESEARCH_ALLOW_EXTERNAL_LLM_FOR_PUBLIC_SOURCES=true
MEDICAL_RESEARCH_ALLOW_EXTERNAL_LLM_FOR_PRIVATE_SOURCES=false

# Optional. Semantic Scholar works without a key at lower public rate limits.
MEDICAL_RESEARCH_SEMANTIC_SCHOLAR_API_KEY=
